pipeline {
    agent any

    environment {
        IMAGE_NAME = "nikitaram2799/devops-app"
        AWS_REGION = "us-east-2"                // Change to your region
        KUBECONFIG_PATH = "/var/jenkins_home/.kube/config"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/nikitaram882799/devops-project.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME app/'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withDockerRegistry([credentialsId: 'dockerhub-cred', url: '']) {
                    sh 'docker push $IMAGE_NAME'
                }
            }
        }

        stage('Configure AWS & Kubeconfig') {
            steps {
                // AWS credentials stored in Jenkins (ID: aws-eks-cred)
                withAWS(credentials: 'aws-eks-cred', region: "$AWS_REGION") {
                    // Create kubeconfig automatically for EKS cluster
                    sh "aws eks update-kubeconfig --name devops-cluster --region $AWS_REGION"
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                // Deploy Kubernetes manifests
                sh 'kubectl apply -f k8s/deployment.yaml'
                sh 'kubectl apply -f k8s/service.yaml'
            }
        }
    }
}